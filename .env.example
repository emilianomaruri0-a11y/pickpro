# Copy this file to .env and add your real provider keys.

# Free-safe sports odds provider settings.
# Start with a small set to avoid spending the free quota too fast.
THE_ODDS_API_KEY=put_your_key_here
ODDS_REGIONS=us
ODDS_MARKETS=h2h
SPORT_KEYS=baseball_mlb,soccer_fifa_world_cup

# The UI streams updated probabilities every second.
# Keep API polling higher to avoid exhausting the provider quota.
POLL_INTERVAL_MS=10800000
LIVE_TICK_INTERVAL_MS=1000
EVENT_CACHE_TTL_HOURS=36
PORT=4173

# When you have more quota, you can expand with:
# ODDS_REGIONS=us,eu,uk
# ODDS_MARKETS=h2h,spreads,totals
# Only the current World Cup:
# SPORT_KEYS=soccer_fifa_world_cup
# More sports when you have more quota:
# SPORT_KEYS=soccer_fifa_world_cup,soccer_mexico_ligamx,soccer_epl,soccer_spain_la_liga,soccer_uefa_champs_league,basketball_nba,basketball_wnba,baseball_mlb,americanfootball_nfl,icehockey_nhl,tennis_atp,tennis_wta,mma_mixed_martial_arts,boxing_boxing

# Optional Google login
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APP_BASE_URL=http://localhost:4173
