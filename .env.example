# Copy this file to .env and add your real provider keys.

# Free-safe sports odds provider settings.
# Start with a small set to avoid spending the free quota too fast.
THE_ODDS_API_KEY=put_your_key_here
ODDS_REGIONS=us
ODDS_MARKETS=h2h
SPORT_KEYS=soccer_mexico_ligamx,soccer_epl,soccer_uefa_champs_league,soccer_uefa_europa_league,soccer_spain_la_liga

# The UI streams updated probabilities every second.
# Keep API polling higher to avoid exhausting the provider quota.
POLL_INTERVAL_MS=43200000
LIVE_TICK_INTERVAL_MS=1000
SCORE_POLL_INTERVAL_MS=1800000
PROVIDER_CREDIT_RESERVE=60
EVENT_CACHE_TTL_HOURS=36
PORT=4173

# Optional persistent user database. Use this in Render so accounts survive deploys/restarts.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_KV_TABLE=pickpro_kv

# When you have more quota, you can expand with:
# ODDS_REGIONS=us,eu,uk
# ODDS_MARKETS=h2h,spreads,totals
# Reduce further if your remaining quota is low:
# SPORT_KEYS=soccer_mexico_ligamx,soccer_epl,soccer_uefa_champs_league
